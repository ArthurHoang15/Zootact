# Zootact AI Service Configuration
# Copy this file to .env and update values as needed

# Debug mode (set to true for development)
DEBUG=false

# Redis connection URL for fetching game state
REDIS_URL=redis://localhost:6379

# AI Engine Settings
MAX_SEARCH_DEPTH=8
DEFAULT_SEARCH_DEPTH=4
MAX_RESPONSE_TIME_MS=200

# Bot Detection Thresholds
# StdDev below this threshold is flagged as suspicious
BOT_DETECTION_STDDEV_THRESHOLD_MS=50.0
# Coefficient of variation threshold
BOT_DETECTION_CV_THRESHOLD=0.05
# Minimum moves needed for reliable bot detection
MIN_MOVES_FOR_DETECTION=10

# Logging
LOG_LEVEL=INFO
