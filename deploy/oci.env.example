# Copy this file to .env.production on the OCI VM and fill real values there.
# Keep .env.production out of Git.

# Public backend host managed by a free DDNS provider or your own domain.
PUBLIC_HOST=zootact-api.example.com

# Cloudflare Pages frontend origins allowed by backend CORS.
# Include both your production Pages domain and preview domain if needed.
FRONTEND_ALLOWED_ORIGINS=https://zootact.pages.dev

# Internal Docker IP of the Caddy reverse proxy trusted for forwarded headers.
CADDY_INTERNAL_IP=172.18.0.2

# PostgreSQL container credentials.
POSTGRES_DB=zootact
POSTGRES_USER=zootact
POSTGRES_PASSWORD=change-me-postgres-password

# Redis password used by game live state and SignalR scale-out.
REDIS_PASSWORD=change-me-redis-password

# Firebase Admin service-account JSON encoded as base64.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=change-me-base64-json

# Production v1 keeps AI analysis disabled. Enable after deploying ai-service.
AI_SERVICE_ENABLED=false
AI_SERVICE_BASE_URL=http://ai-service:8001
